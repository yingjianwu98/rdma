#!/bin/bash
# Run Mu watch benchmark

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source "$SCRIPT_DIR/cluster_info.sh"

echo "========================================="
echo "Running Mu Watch Benchmark"
echo "========================================="
echo ""

# Update strategy in main.cpp
echo "Setting strategy to 'mu_watch'..."
ssh "${NODES[0]}" "cd ~/rdma && sed -i 's/constexpr const char\* STRATEGY = \".*\";/constexpr const char* STRATEGY = \"mu_watch\";/' src/main.cpp"

# Recompile on all nodes
echo "Recompiling on all nodes..."
for node in "${NODES[@]}"; do
    ssh "$node" "cd ~/rdma/build && make -j > /dev/null 2>&1" &
done
wait
echo "✓ Recompiled"
echo ""

# Start server processes in background
echo "Starting $NUM_NODES server processes..."
for i in "${!NODES[@]}"; do
    node="${NODES[$i]}"
    echo "  Starting server on Node$i ($node)..."
    ssh "$node" "cd ~/rdma/build && NODE_ID=$i IS_CLIENT=0 nohup ./rdma > server_$i.log 2>&1 &" &
done
wait
sleep 2
echo "✓ Servers started"
echo ""

# Run client on Node0
echo "Running client on Node0..."
echo "(This will take ~30 seconds...)"
echo ""
ssh "${NODES[0]}" "cd ~/rdma/build && IS_CLIENT=1 MACHINE_ID=0 ./rdma" | tee mu_watch_results.txt

echo ""
echo "✓ Benchmark complete!"
echo ""

# Kill server processes
echo "Stopping servers..."
for node in "${NODES[@]}"; do
    ssh "$node" "pkill -f './rdma' || true" &
done
wait
echo "✓ Servers stopped"
echo ""

echo "Results saved to: mu_watch_results.txt"
echo ""
